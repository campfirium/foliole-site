---
const { title, description, entries, currentId } = Astro.props;

const allEntries = entries ?? [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title} - Foliole Guides</title>
    <meta name="description" content={description}>
    <meta property="og:title" content={`${title} - Foliole Guides`}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="article">
    <meta property="og:image" content="https://foliole.app/assets/brand/foliole-app-icon.svg">
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()}>
    <link rel="icon" href="/assets/brand/favicon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="/styles.css?v=000016">
  </head>
  <body class="guide-body">
    <div class="guide-app">
      <header class="guide-titlebar" aria-label="Window title">
        <div class="guide-titlebar-left">
          <span class="guide-titlebar-icon" aria-hidden="true"></span>
        </div>
        <div class="guide-titlebar-title">Foliole Guides</div>
        <div class="guide-titlebar-controls" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </header>

      <aside class="guide-rail" aria-label="Guides sections">
        <span class="guide-rail-mark" aria-hidden="true">
          <img src="/assets/brand/foliole-app-icon.svg" alt="">
        </span>
        <span class="guide-rail-button" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M6 4.5h12v15H6z"></path>
            <path d="M9 8h6"></path>
            <path d="M9 12h6"></path>
          </svg>
        </span>
        <span class="guide-rail-button is-active" aria-hidden="true">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 5.5h10"></path>
            <path d="M7 12h10"></path>
            <path d="M7 18.5h10"></path>
          </svg>
        </span>
        <span class="guide-rail-spacer"></span>
        <span class="guide-rail-button" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M12 3a6.8 6.8 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
        </span>
        <span class="guide-rail-button" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path d="M4 21v-7"></path>
            <path d="M4 10V3"></path>
            <path d="M12 21v-9"></path>
            <path d="M12 8V3"></path>
            <path d="M20 21v-5"></path>
            <path d="M20 12V3"></path>
          </svg>
        </span>
      </aside>

      <aside class="guide-directory" aria-label="Guides directory">
        <div class="guide-directory-tools" aria-hidden="true">
          <span></span>
          <span></span>
        </div>
        <div class="guide-directory-list">
          <div class="guide-directory-row">
            <span class="guide-row-caret">⌄</span>
            <span>Home</span>
            <small>0</small>
          </div>
          <div class="guide-directory-row is-active">
            <span class="guide-row-caret"></span>
            <span>Guides</span>
            <small>{allEntries.length}</small>
          </div>
        </div>
      </aside>

      <aside class="guide-list" aria-label="Guides articles">
        <div class="guide-list-tools" aria-label="Article list tools">
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="5"></circle><path d="m15 15 4 4"></path></svg>
          </span>
          <span class="guide-list-tool-spacer"></span>
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M8 7h8"></path><path d="M8 12h6"></path><path d="M8 17h4"></path></svg>
          </span>
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="m7 10 5-5 5 5"></path><path d="m7 14 5 5 5-5"></path></svg>
          </span>
        </div>
        <div class="guide-list-header">
          <span>Guides</span>
          <span>{allEntries.length}</span>
        </div>
        {allEntries.length > 0 && (
          <nav>
            {allEntries.map((entry) => (
              <a class={entry.id === currentId ? 'is-active' : ''} href={`/guides/${entry.id}/`}>
                <span>{entry.data.title}</span>
                <small>{entry.data.category}</small>
              </a>
            ))}
          </nav>
        )}
      </aside>

      <main class="guide-reader" aria-labelledby="guide-title">
        <header class="guide-reader-top">
          <div class="guide-reader-history" aria-hidden="true">
            <span>‹</span>
            <span>›</span>
          </div>
          <nav class="guide-breadcrumb" aria-label="Breadcrumb">
            <span>Foliole</span>
            <span>/</span>
            <span>Guides</span>
          </nav>
          <span class="guide-reader-page">P1</span>
        </header>
        <article class="guide-article">
          <slot />
        </article>
      </main>

      <footer class="guide-status">
        <span>Static Guides view - not the Foliole app.</span>
      </footer>
    </div>
  </body>
</html>
