---
const { title, description, guides, guide, runtime, canonicalPath } = Astro.props;

const allGuides = guides ?? [];
const currentGuide = guide ?? allGuides[0];
const pageTitle = title === 'Foliole Guides' ? title : `${title} - Foliole Guides`;
const pageDescription = description ?? currentGuide?.description ?? 'Foliole Guides';
const pagePath = canonicalPath ?? currentGuide?.canonicalPath ?? '/guides/';
const canonicalUrl = new URL(pagePath, Astro.site).toString();
const runtimeAssets = runtime?.assets ?? [];
const styleAssets = runtimeAssets.filter((asset) => asset.type === 'style');
const scriptAssets = runtimeAssets.filter((asset) => asset.type === 'script');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription}>
    <meta property="og:title" content={pageTitle}>
    <meta property="og:description" content={pageDescription}>
    <meta property="og:type" content="article">
    <meta property="og:image" content="https://foliole.app/assets/brand/foliole-app-icon.svg">
    <link rel="canonical" href={canonicalUrl}>
    <link rel="icon" href="/assets/brand/favicon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="/styles.css?v=000020">
    {styleAssets.map((asset) => <link rel="stylesheet" href={`/guides-runtime/${asset.path}`} />)}
    {scriptAssets.map((asset) => <script type="module" src={`/guides-runtime/${asset.path}`}></script>)}
  </head>
  <body class="guide-body">
    <main aria-label="Foliole Guides" class="foliole-guides-runtime">
      <div id="root">
        <section class="foliole-guides-seo" aria-labelledby="guide-title">
          <h1 id="guide-title">{currentGuide?.title ?? 'Foliole Guides'}</h1>
          <p>{currentGuide?.description ?? pageDescription}</p>
          {allGuides.length > 0 && (
            <nav aria-label="Guides">
              {allGuides.map((item) => (
                <a href={item.canonicalPath} aria-current={item.slug === currentGuide?.slug ? 'page' : undefined}>
                  {item.title}
                </a>
              ))}
            </nav>
          )}
          <slot />
        </section>
      </div>
    </main>
  </body>
</html>
