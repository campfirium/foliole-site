---
const { title, description, entries, currentId } = Astro.props;

const allEntries = entries ?? [];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title} - Foliole Guides</title>
    <meta name="description" content={description}>
    <meta property="og:title" content={`${title} - Foliole Guides`}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="article">
    <meta property="og:image" content="https://foliole.app/assets/brand/foliole-app-icon.svg">
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()}>
    <link rel="icon" href="/assets/brand/favicon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="/styles.css?v=000017">
  </head>
  <body class="guide-body">
    <main aria-label="Foliole Guides" class="workspace-responsive-shell foliole-guides-static">
      <header class="window-titlebar" aria-label="Window title">
        <div class="workspace-surface-row-overlay" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
          <span></span>
        </div>
        <div class="workspace-titlebar-dividers" aria-hidden="true">
          <span data-column="rail"></span>
          <span data-column="folder"></span>
          <span data-column="topic"></span>
        </div>
        <div class="window-titlebar-left-zone" data-collapsed="false">
          <div class="window-titlebar-leading">
            <div class="window-titlebar-leading-primary">
              <span class="window-titlebar-leading-button" data-active="true" aria-hidden="true">
                <svg class="window-titlebar-leading-icon" viewBox="0 0 24 24">
                  <path d="M4 5h16"></path>
                  <path d="M4 19h16"></path>
                  <path d="M8 5v14"></path>
                </svg>
              </span>
            </div>
          </div>
        </div>
        <div class="window-titlebar-center-slot window-titlebar-drag-fill" aria-hidden="true">
          <span class="window-titlebar-center-title">Foliole Guides</span>
        </div>
        <div class="window-titlebar-controls" aria-hidden="true">
          <span class="window-titlebar-button">
            <svg class="window-titlebar-icon" viewBox="0 0 12 12"><path d="M2 6h8"></path></svg>
          </span>
          <span class="window-titlebar-button">
            <svg class="window-titlebar-icon" viewBox="0 0 12 12"><rect x="2.5" y="2.5" width="7" height="7"></rect></svg>
          </span>
          <span class="window-titlebar-button window-titlebar-button-close">
            <svg class="window-titlebar-icon" viewBox="0 0 12 12"><path d="m3 3 6 6"></path><path d="m9 3-6 6"></path></svg>
          </span>
        </div>
      </header>

      <section class="foliole-workspace-grid">
        <div class="workspace-grid-divider-overlay" aria-hidden="true">
          <span data-column="rail"></span>
          <span data-column="folder"></span>
          <span data-column="topic"></span>
        </div>

        <aside class="workspace-region-main-rail foliole-static-rail" aria-label="Workspace rail">
          <div class="foliole-rail-top" aria-hidden="true">
            <span class="foliole-rail-action foliole-rail-mark">
              <img src="/assets/brand/foliole-app-icon.svg" alt="">
            </span>
            <span class="foliole-rail-action">
              <svg viewBox="0 0 24 24">
                <path d="M6 4.5h12v15H6z"></path>
                <path d="M9 8h6"></path>
                <path d="M9 12h6"></path>
              </svg>
            </span>
            <span class="foliole-rail-action is-active">
              <svg viewBox="0 0 24 24">
                <path d="M7 5.5h10"></path>
                <path d="M7 12h10"></path>
                <path d="M7 18.5h10"></path>
              </svg>
            </span>
          </div>
          <div class="foliole-rail-bottom" aria-hidden="true">
            <span class="foliole-rail-action">
              <svg viewBox="0 0 24 24"><path d="M12 3a6.8 6.8 0 0 0 9 9 9 9 0 1 1-9-9Z"></path></svg>
            </span>
            <span class="foliole-rail-action">
              <svg viewBox="0 0 24 24">
                <path d="M4 21v-7"></path>
                <path d="M4 10V3"></path>
                <path d="M12 21v-9"></path>
                <path d="M12 8V3"></path>
                <path d="M20 21v-5"></path>
                <path d="M20 12V3"></path>
              </svg>
            </span>
          </div>
        </aside>

        <div class="foliole-workspace-content">
          <aside class="foliole-list-area" aria-label="Guides navigation">
            <div class="workspace-region-main-folder foliole-folder-column">
              <div class="foliole-folder-toolbar" aria-hidden="true">
                <span></span>
                <span></span>
              </div>
              <div class="foliole-tree" role="tree">
                <div class="foliole-tree-row" role="treeitem" aria-expanded="true">
                  <span class="foliole-tree-caret">⌄</span>
                  <span>Home</span>
                  <small>0</small>
                </div>
                <div class="foliole-tree-row is-active" role="treeitem" aria-current="page">
                  <span class="foliole-tree-caret"></span>
                  <span>Guides</span>
                  <small>{allEntries.length}</small>
                </div>
              </div>
            </div>

            <div class="workspace-region-main-topic foliole-topic-column">
              <div class="foliole-topic-toolbar" aria-label="Guides list tools">
                <span aria-hidden="true">
                  <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="5"></circle><path d="m15 15 4 4"></path></svg>
                </span>
                <span class="foliole-topic-toolbar-spacer"></span>
                <span aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="M8 7h8"></path><path d="M8 12h6"></path><path d="M8 17h4"></path></svg>
                </span>
                <span aria-hidden="true">
                  <svg viewBox="0 0 24 24"><path d="m7 10 5-5 5 5"></path><path d="m7 14 5 5 5-5"></path></svg>
                </span>
              </div>
              <div class="foliole-topic-header">
                <span>Guides</span>
                <small>{allEntries.length}</small>
              </div>
              {allEntries.length > 0 && (
                <nav class="foliole-topic-list">
                  {allEntries.map((entry) => (
                    <a class={entry.id === currentId ? 'is-active' : ''} href={`/guides/${entry.id}/`}>
                      <span>{entry.data.title}</span>
                      <small>{entry.data.category}</small>
                    </a>
                  ))}
                </nav>
              )}
            </div>
          </aside>

          <main class="workspace-region-main-document foliole-document-area" aria-labelledby="guide-title">
            <header class="foliole-document-header">
              <div class="foliole-document-nav" aria-hidden="true">
                <span>‹</span>
                <span>›</span>
              </div>
              <div class="foliole-document-breadcrumb" aria-label="Breadcrumb">
                <span>Foliole</span>
                <span>/</span>
                <span>Guides</span>
              </div>
              <span class="foliole-document-page">P1</span>
            </header>
            <article class="foliole-document-body">
              <slot />
            </article>
          </main>
        </div>

        <footer class="workspace-bottom-region-grid foliole-guides-footer">
          <div class="workspace-surface-row-overlay" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
          </div>
          <span>Static Guides view - not the Foliole app.</span>
        </footer>
      </section>
    </main>
  </body>
</html>
