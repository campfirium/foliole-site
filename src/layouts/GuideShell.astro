---
const { title, description, entries, currentId } = Astro.props;

const allEntries = entries ?? [];
const currentEntry = allEntries.find((entry) => entry.id === currentId);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title} - Foliole Guides</title>
    <meta name="description" content={description}>
    <meta property="og:title" content={`${title} - Foliole Guides`}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="article">
    <meta property="og:image" content="https://foliole.app/assets/brand/foliole-app-icon.svg">
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()}>
    <link rel="icon" href="/assets/brand/favicon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="/styles.css?v=000020">
  </head>
  <body class="guide-body">
    <main aria-label="Foliole Guides" class="foliole-guides-runtime">
      <iframe
        class="foliole-guides-runtime-frame"
        src="/guides-runtime/index.html"
        title="Foliole Guides workspace"
      ></iframe>
      <section class="foliole-guides-seo" aria-labelledby="guide-title">
        <h1 id="guide-title">{currentEntry?.data.title ?? 'Foliole Guides'}</h1>
        <p>Static Guides view rendered by the Foliole workspace runtime. This page is documentation, not the Foliole app.</p>
        <slot />
      </section>
    </main>
  </body>
</html>
