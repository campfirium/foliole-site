---
const { title, description, entries, currentId } = Astro.props;

const allEntries = entries ?? [];
const categories = [...new Set(allEntries.map((entry) => entry.data.category))];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{title} - Foliole Guides</title>
    <meta name="description" content={description}>
    <meta property="og:title" content={`${title} - Foliole Guides`}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="article">
    <meta property="og:image" content="https://foliole.app/assets/brand/foliole-app-icon.svg">
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site).toString()}>
    <link rel="icon" href="/assets/brand/favicon.png" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="/styles.css?v=000015">
    <script is:inline>window.FOLIOLE_PAGE_COPY={"theme":{"system":"Theme: follow browser","light":"Theme: light","dark":"Theme: dark"}};</script>
  </head>
  <body class="guide-body">
    <div class="guide-app">
      <header class="guide-titlebar" aria-label="Window title">
        <div class="guide-titlebar-left">
          <span class="guide-titlebar-icon" aria-hidden="true"></span>
        </div>
        <div class="guide-titlebar-title">Foliole Guides</div>
        <div class="guide-titlebar-controls" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </div>
      </header>

      <aside class="guide-rail" aria-label="Guides sections">
        <a class="guide-home-mark" href="/" aria-label="Foliole home">
          <img src="/assets/brand/foliole-app-icon.svg" alt="">
        </a>
        <a class="guide-rail-button is-active" href="/guides/" aria-label="Guides">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M7 5.5h10"></path>
            <path d="M7 12h10"></path>
            <path d="M7 18.5h10"></path>
          </svg>
        </a>
        <span class="guide-rail-spacer"></span>
        <button class="guide-rail-button" type="button" aria-label="Theme: follow browser" title="Theme: follow browser" data-theme-toggle>
          <svg class="theme-icon theme-icon-system" viewBox="0 0 24 24" aria-hidden="true">
            <rect x="3" y="4" width="18" height="13" rx="2"></rect>
            <path d="M8 21h8"></path>
            <path d="M12 17v4"></path>
          </svg>
          <svg class="theme-icon theme-icon-light" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
          </svg>
          <svg class="theme-icon theme-icon-dark" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M12 3a6.8 6.8 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
        </button>
      </aside>

      <aside class="guide-directory" aria-label="Guides directory">
        <div class="guide-directory-tools" aria-hidden="true">
          <span></span>
          <span></span>
        </div>
        <nav class="guide-directory-list">
          <a href="/" class="guide-directory-row">
            <span class="guide-row-caret">⌄</span>
            <span>Home</span>
            <small>0</small>
          </a>
          <a href="/guides/" class="guide-directory-row is-active">
            <span class="guide-row-caret"></span>
            <span>Guides</span>
            <small>{allEntries.length}</small>
          </a>
        </nav>
        {categories.length > 0 && (
          <nav class="guide-category-list">
            {categories.map((category) => (
              <a class={allEntries.some((entry) => entry.id === currentId && entry.data.category === category) ? 'is-active' : ''} href={`/guides/#${category.toLowerCase().replaceAll(' ', '-')}`}>
                <span>{category}</span>
                <small>{allEntries.filter((entry) => entry.data.category === category).length}</small>
              </a>
            ))}
          </nav>
        )}
      </aside>

      <aside class="guide-list" aria-label="Guides articles">
        <div class="guide-list-tools" aria-label="Article list tools">
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="5"></circle><path d="m15 15 4 4"></path></svg>
          </span>
          <span class="guide-list-tool-spacer"></span>
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="M8 7h8"></path><path d="M8 12h6"></path><path d="M8 17h4"></path></svg>
          </span>
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24"><path d="m7 10 5-5 5 5"></path><path d="m7 14 5 5 5-5"></path></svg>
          </span>
        </div>
        <div class="guide-list-header">
          <span>Guides</span>
          <span>{allEntries.length}</span>
        </div>
        {allEntries.length > 0 && (
          <nav>
            {allEntries.map((entry) => (
              <a class={entry.id === currentId ? 'is-active' : ''} href={`/guides/${entry.id}/`}>
                <span>{entry.data.title}</span>
                <small>{entry.data.category}</small>
              </a>
            ))}
          </nav>
        )}
      </aside>

      <main class="guide-reader" aria-labelledby="guide-title">
        <header class="guide-reader-top">
          <div class="guide-reader-history" aria-hidden="true">
            <span>‹</span>
            <span>›</span>
          </div>
          <nav class="guide-breadcrumb" aria-label="Breadcrumb">
            <a href="/">Foliole</a>
            <span>/</span>
            <a href="/guides/">Guides</a>
          </nav>
          <span class="guide-reader-page">P1</span>
        </header>
        <article class="guide-article">
          <slot />
        </article>
      </main>

      <footer class="guide-status">
        <span>Static website page - not the Foliole app.</span>
      </footer>
    </div>
    <script is:inline>
      (function () {
        var themeModes = ['system', 'light', 'dark'];
        var media = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;
        var button = document.querySelector('[data-theme-toggle]');
        var pageCopy = window.FOLIOLE_PAGE_COPY || {};
        var themeCopy = pageCopy.theme || {};

        function storedTheme() {
          var saved = localStorage.getItem('foliole-theme');
          return themeModes.indexOf(saved) >= 0 ? saved : 'system';
        }

        function themeLabel(mode) {
          if (mode === 'light') return themeCopy.light || 'Theme: light';
          if (mode === 'dark') return themeCopy.dark || 'Theme: dark';
          return themeCopy.system || 'Theme: follow browser';
        }

        function applyTheme(mode) {
          var effective = mode === 'system' && media && media.matches ? 'dark' : mode === 'dark' ? 'dark' : 'light';
          document.documentElement.dataset.themeMode = mode;
          document.documentElement.dataset.theme = effective;
          if (button) {
            button.setAttribute('aria-label', themeLabel(mode));
            button.setAttribute('title', themeLabel(mode));
          }
        }

        window.setFolioleTheme = function (mode, persist) {
          var next = themeModes.indexOf(mode) >= 0 ? mode : 'system';
          applyTheme(next);
          if (persist) localStorage.setItem('foliole-theme', next);
        };

        if (button) {
          button.addEventListener('click', function () {
            var current = document.documentElement.dataset.theme === 'dark' ? 'dark' : 'light';
            var next = current === 'dark' ? 'light' : 'dark';
            window.setFolioleTheme(next, true);
          });
        }

        if (media) {
          var onChange = function () {
            if (storedTheme() === 'system') applyTheme('system');
          };
          if (media.addEventListener) media.addEventListener('change', onChange);
          else if (media.addListener) media.addListener(onChange);
        }

        applyTheme(storedTheme());
      })();
    </script>
  </body>
</html>
