---
import { locales, renderHomePage } from '../../lib/home-renderer.mjs';

export function getStaticPaths() {
  return locales
    .filter((locale) => locale.path)
    .map((locale) => ({
      params: { localePath: locale.path },
      props: { localeId: locale.id }
    }));
}

const html = await renderHomePage(Astro.props.localeId);
---

<Fragment set:html={html} />
