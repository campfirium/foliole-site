---
import { getCollection, render } from 'astro:content';
import GuideShell from '../../layouts/GuideShell.astro';

export async function getStaticPaths() {
  const entries = await getCollection('guide');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry }
  }));
}

const entries = (await getCollection('guide')).sort((a, b) => a.data.order - b.data.order);
const { entry } = Astro.props;
const { Content, headings } = await render(entry);
---

<GuideShell
  title={entry.data.title}
  description={entry.data.description}
  entries={entries}
  currentId={entry.id}
  headings={headings}
  flow={entry.data.flow}
>
  <h1 id="guide-title">{entry.data.title}</h1>
  <p class="guide-kicker">{entry.data.description}</p>
  <Content />
</GuideShell>
